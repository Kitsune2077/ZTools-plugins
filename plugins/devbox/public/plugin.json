  "categories": ["development"],
  "description": "开发百宝箱，提供随机生成、编码转换、文本压缩、文本转换、JSON 工具、开发辅助等常用工具集",
  "author": "咖啡八杯",
  "version": "2.5.0",
  "main": "index.html",
  "preload": "preload/services.js",
  "logo": "logo.png",
  "development": {
    "main": "http://localhost:5173"
  },
  "features": [
