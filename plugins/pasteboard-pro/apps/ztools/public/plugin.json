{
  "$schema": "node_modules/@ztools-center/ztools-api-types/resource/ztools.schema.json",
  "name": "pasteboard-pro",
  "title": "PasteboardPro",
  "description": "Paste 风格的本地剪贴板历史、Pinboards 与 Paste Stack",
  "author": "TheLastSheep",
  "version": "1.0.0",
  "main": "index.html",
  "preload": "preload.js",
  "logo": "logo.svg",
  "platform": ["darwin", "win32", "linux"],
  "features": [
    {
      "code": "pasteboard-pro",
      "explain": "打开 PasteboardPro 剪贴板历史",
      "icon": "logo.svg",
      "cmds": ["剪贴板", "PasteboardPro", "paste", "clipboard"]
    }
  ],
  "tools": {
    "search_history": {
      "description": "搜索 PasteboardPro 本地剪贴板历史",
      "inputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "query": {
            "type": "string",
            "description": "文本或 type/app/device/date/pinboard 过滤表达式"
          },
          "limit": {
            "type": "integer",
            "minimum": 1,
            "maximum": 100,
            "default": 20
          }
        },
        "required": []
      },
      "outputSchema": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "id": { "type": "string" },
                "kind": { "type": "string" },
                "title": { "type": "string" },
                "copiedAt": { "type": "string" }
              },
              "required": ["id", "kind", "copiedAt"]
            }
          },
          "total": { "type": "integer", "minimum": 0 }
        },
        "required": ["items", "total"]
      }
    }
  }
}
